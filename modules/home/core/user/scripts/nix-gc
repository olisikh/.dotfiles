#!/usr/bin/env bash

set -euo pipefail

. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/lib.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--keep N] [--dry-run]

Prune nix-darwin system generations, retaining the newest 10 by default, then
run garbage collection. Pass --keep N to retain a different number.
EOF
}

main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        usage
        exit 0
    fi

    check_command nix-prune-system-generations
    nix-prune-system-generations "$@"
}

main "$@"

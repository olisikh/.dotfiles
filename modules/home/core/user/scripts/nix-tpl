#!/usr/bin/env bash

set -euo pipefail

. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/lib.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") <template> [nix flake init args...]

Instantiate a template from this dotfiles flake.
EOF
}

main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        usage
        exit 0
    fi

    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    local template="$1"
    shift

    check_command nix
    nix flake init -t "$NIX_DOTFILES_ROOT#$template" "$@"
}

main "$@"

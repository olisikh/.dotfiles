#!/usr/bin/env python3
"""Fail unless the local Plane proxy responds to an HTTP request."""
from __future__ import annotations

import os
import sys
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

host = os.environ.get("PLANE_TAILNET_HOST", "olisikh-mini.bandicoot-scala.ts.net")
port = os.environ.get("PLANE_PROXY_PORT", "28080")
request = Request(f"http://127.0.0.1:{port}/", headers={"Host": host})
try:
    with urlopen(request, timeout=10) as response:
        code = response.status
except HTTPError as exc:
    code = exc.code
except URLError as exc:
    raise SystemExit(f"Plane proxy unreachable: {exc}") from exc

if not 200 <= code < 500:
    raise SystemExit(f"Plane proxy returned unexpected status {code}")
print(f"Plane proxy reachable: HTTP {code}")
